{
  "name": "27",
  "version": "1.0.0",
  "description": "27 ephemeral private chat app.",
  "homepage": "https://abadi04.github.io/27/",
  "private": true,
  "scripts": {
    "build": "esbuild public/js/app-entry.js --bundle --outfile=public/app.js --format=iife",
